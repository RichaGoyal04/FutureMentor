# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-in-production

# IBM watsonx.ai API key  →  https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=qOaXTcjCC0TR9vQdMoempYxbrtI6O9Db49p0wJU_U6ny

# watsonx.ai Project ID   →  https://dataplatform.cloud.ibm.com/projects
# Open your project → Manage → General → copy Project ID
IBM_PROJECT_ID=4df7bcf9-0556-460b-be86-513efa48fe80

# ── Regional endpoint ──────────────────────────────────────────
# us-south (Dallas)   →  https://us-south.ml.cloud.ibm.com  ← RECOMMENDED
# eu-de   (Frankfurt) →  https://eu-de.ml.cloud.ibm.com
# au-syd  (Sydney)    →  https://au-syd.ml.cloud.ibm.com    (limited models)
# eu-gb   (London)    →  https://eu-gb.ml.cloud.ibm.com     (limited models)
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ── Model (verified 2026) ─────────────────────────────────────
# granite-3-8b-instruct  WITHDRAWN since 2026-03-31 — do not use
# granite-4-h-small      ✅ Active, uses Chat API  ← RECOMMENDED
# granite-3-1-8b-base    ✅ Active (generation API still works)
WATSONX_MODEL_ID=ibm/granite-4-h-small

# App
APP_HOST=0.0.0.0
APP_PORT=5000
DEBUG=False
